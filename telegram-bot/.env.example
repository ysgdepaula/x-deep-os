# X-DEEP OS — Telegram Bot Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.

# === Required ===

# Your Telegram bot token (get one from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID (get from @userinfobot) — restricts who can talk to the bot
TELEGRAM_USER_ID=

# Anthropic API key (for Claude)
ANTHROPIC_API_KEY=

# OpenAI API key (for Whisper voice transcription). Optional if you don't use voice messages.
OPENAI_API_KEY=

# === Your agent identity ===

# The name of your DEEP instance (e.g. M-DEEP for Marc, A-DEEP for Alex, Y-DEEP for Yan)
DEEP_NAME=X-DEEP

# Your name as the user of the agent
USER_NAME=

# Language for assistant replies and voice transcription (ISO 639-1: en, fr, de, ...)
ASSISTANT_LANG=en
WHISPER_LANG=en

# === Redis (state + queue) ===

# Redis connection URL. Use Upstash for a free managed Redis (https://upstash.com)
REDIS_URL=redis://localhost:6379

# Key prefix for this deployment (lets multiple DEEPs share one Redis without colliding)
REDIS_PREFIX=xdeep

# Stream name for internal events
REDIS_EVENTS_STREAM=xdeep:events

# === GitHub (self-healing loop) ===

# GitHub personal access token with `repo` + `workflow` scopes
GITHUB_TOKEN=

# Your repo (owner and name separated) — where auto-fix issues/PRs are created
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Full HTTPS URL (optional — enables context.syncRepo to auto-pull the repo)
GITHUB_REPO_URL=

# === Bot self-healing paths ===

# Where the bot code lives relative to repo root (used by the fix agent)
BOT_SRC_PATH=telegram-bot/src
BOT_ENTRY_FILE=index.mjs

# === MCP servers (optional, depends on your setup) ===

# Path to your MCP servers directory (default: ./mcp-servers relative to repo root)
MCP_SERVERS_PATH=./mcp-servers

# Default agent id when approvals can't detect the source agent
DEFAULT_AGENT_ID=xdeep-master
